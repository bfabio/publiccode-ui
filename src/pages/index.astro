---
import Layout from '../layouts/Layout.astro';
import { fetchAllSoftware } from '../lib/api.js';
import { base } from '../lib/url.js';

const software = await fetchAllSoftware();
---

<Layout title="EU Public Code">
  <h1>Software ({software.length})</h1>
  <ul>
    {software.map((s) => (
      <li>
        <a href={`${base}/software/${s.id}`}>
          <strong>{s.publiccode.name}</strong>
        </a>
        — {s.publiccode.legal?.license}<br />
        <small>{s.publiccode.description?.en?.shortDescription ?? s.publiccode.description?.[Object.keys(s.publiccode.description)[0]]?.shortDescription}</small>
      </li>
    ))}
  </ul>
</Layout>
