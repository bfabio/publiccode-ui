---
import { base } from '../lib/url.js';
const target = base + '/software/';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <title>Redirecting</title>
  </head>
  <body>
    <a href={target}>Software catalog</a>
  </body>
</html>
