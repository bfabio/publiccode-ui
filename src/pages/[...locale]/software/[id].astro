---
import Layout from '../../../layouts/Layout.astro';
import { fetchAllSoftware } from '../../../lib/api.js';
import { resolveLogo, absoluteUrl } from '../../../lib/absoluteUrl.js';
import { base } from '../../../lib/url.js';
import { Marked } from 'marked';
const marked = new Marked({ renderer: { html() { return ''; } } });
import { t, localizeDescription } from '../../../lib/i18n.js';
import { formatDate } from '../../../lib/date.js';
import { resolveLicense } from '../../../lib/license.js';

export async function getStaticPaths() {
  const software = await fetchAllSoftware();
  const locales = [undefined, 'it'];
  return locales.flatMap((locale) =>
    software.map((s) => ({
      params: { locale, id: s.id },
      props: { software: s },
    }))
  );
}

const locale = Astro.currentLocale ?? 'en';
const { software } = Astro.props;
const pc = software.publiccode;

const desc = localizeDescription(pc.description, locale);
const logo = resolveLogo(pc);
const longDescriptionHtml = desc.longDescription ? marked.parse(desc.longDescription) : null;
const screenshots = (desc.screenshots ?? [])
  .map((s) => absoluteUrl(s, pc.url))
  .filter(Boolean);
const release = formatDate(pc.releaseDate, locale);
const license = await resolveLicense(pc.legal?.license);
---

<Layout title={pc.name} breadcrumbs={[{ label: "Home", href: base + "/" }, { label: "Software", href: base + "/software" }, { label: pc.name }]}>
  <style>
    .header { display: flex; gap: 2rem; align-items: flex-start; margin-bottom: 2rem; }
    .header img { border-radius: 8px; }
    .header-info { flex: 1; }
    h1 { margin-bottom: 0.25rem; }
    .short-desc { font-size: 1.1rem; color: #555; margin: 0.5rem 0 1rem; }
    .categories { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .cat { font-size: 0.75rem; background: #f0f0f0; border-radius: 4px; padding: 2px 8px; text-transform: uppercase; }
    dl { display: grid; grid-template-columns: auto 1fr; gap: 0.25rem 1.5rem; margin: 1.5rem 0; }
    dt { font-weight: 600; font-size: 0.85rem; text-transform: uppercase; color: #888; }
    dd { margin: 0; word-break: break-all; }
    dd a { color: #0066cc; text-decoration: none; }
    dd a:hover { text-decoration: underline; }
    h2 { font-size: 1.3rem; margin-top: 2rem; border-bottom: 1px solid #e0e0e0; padding-bottom: 0.5rem; }
    .screenshots { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1rem; }
    .screenshots img { max-height: 200px; max-width: 300px; object-fit: contain; border: 1px solid #e0e0e0; border-radius: 4px; }
    .long-desc { line-height: 1.7; }
    .long-desc img { max-width: 100%; }
  </style>

  <div class="header">
    {logo && <img src={logo} alt="" width="100" onerror="this.style.display='none'" />}
    <div class="header-info">
      <h1>{pc.name}</h1>
      <p class="short-desc">{desc.shortDescription}</p>
      {pc.categories?.length > 0 && (
        <div class="categories">
          {pc.categories.map((c) => <span class="cat">{c}</span>)}
        </div>
      )}
    </div>
  </div>

  <dl>
    {license && <><dt>{t(locale, 'license')}</dt><dd>{license.url ? <a href={license.url}>{license.name}</a> : license.name}</dd></>}
    {release && <><dt>{t(locale, 'release_date')}</dt><dd><time datetime={release.datetime} title={release.formatted}>{release.relative}</time></dd></>}
    {pc.softwareVersion && <><dt>{t(locale, 'version')}</dt><dd>{pc.softwareVersion}</dd></>}
    {pc.developmentStatus && <><dt>{t(locale, 'status')}</dt><dd>{pc.developmentStatus}</dd></>}
    {pc.url && <><dt>{t(locale, 'repository')}</dt><dd><a href={pc.url}>{pc.url}</a></dd></>}
    {pc.landingURL && <><dt>{t(locale, 'website')}</dt><dd><a href={pc.landingURL}>{pc.landingURL}</a></dd></>}
  </dl>

  {screenshots.length > 0 && (
    <div>
      <h2>{t(locale, 'screenshots')}</h2>
      <div class="screenshots">
        {screenshots.map((src) => (
          <a href={src} target="_blank" rel="noopener">
            <img src={src} alt="" loading="lazy" />
          </a>
        ))}
      </div>
    </div>
  )}

  {longDescriptionHtml && (
    <div>
      <h2>{t(locale, 'description')}</h2>
      <div class="long-desc" set:html={longDescriptionHtml} />
    </div>
  )}

  {pc.maintenance?.contacts?.length > 0 && (
    <div>
      <h2>{t(locale, 'contacts')}</h2>
      <ul>
        {pc.maintenance.contacts.map((c) => (
          <li>
            {c.email ? <a href={`mailto:${c.email}`}>{c.name}</a> : c.name}
            {c.phone && <> — {c.phone}</>}
          </li>
        ))}
      </ul>
    </div>
  )}
</Layout>
