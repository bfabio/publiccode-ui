---
import Layout from '../../../layouts/Layout.astro';
import { faIcon } from '../../../lib/icons.js';
import { fetchAllSoftware, fetchCatalogs, fetchAllSoftwareAnalysis, fetchAllOpenCodeBadges, fetchAllCatalogAnalysis, fetchRootCatalogAnalysis } from '../../../lib/api.js';
import { SoftwareMetrics } from '../../../components/SoftwareMetrics';
import { ActivityRadar } from '../../../components/ActivityRadar';
import { resolveLogoAsset, resolveScreenshotAssets } from '../../../lib/assets.js';
import { base } from '../../../lib/url.js';
import { renderMarkdown } from '../../../lib/markdown.ts';
import { t, localizeDescription } from '../../../lib/i18n.js';
import { usableStats } from '../../../lib/activity.ts';
import { formatDate } from '../../../lib/date.js';
import { resolveLicense } from '../../../lib/license.js';
import { safeUrl } from '../../../lib/sanitize.js';

export async function getStaticPaths() {
  const software = await fetchAllSoftware();
  const catalogs = await fetchCatalogs();
  const catalogMap = Object.fromEntries(catalogs.map((c) => [c.id, c]));
  const multiCatalog = catalogs.length > 1;
  const softwareAnalysis = await fetchAllSoftwareAnalysis();
  const openCodeBadges = await fetchAllOpenCodeBadges();
  const catalogAnalysis = await fetchAllCatalogAnalysis();
  const rootAnalysis = await fetchRootCatalogAnalysis();
  const locales = [undefined, 'it'];
  return locales.flatMap((locale) =>
    software.map((s) => ({
      params: { locale, id: s.id },
      props: {
        software: s,
        catalogName: catalogMap[s.catalogId]?.name ?? null,
        multiCatalog,
        activity: softwareAnalysis.get(s.id) ?? null,
        badges: openCodeBadges.get(s.id) ?? null,
        stats: usableStats(rootAnalysis) ?? usableStats(catalogAnalysis.get(s.catalogId) ?? null),
      },
    }))
  );
}

const locale = Astro.currentLocale ?? 'en';
const { software, catalogName, multiCatalog, activity, badges, stats } = Astro.props;
const pc = software.publiccode;

const desc = localizeDescription(pc.description, locale);
const logo = resolveLogoAsset(pc);
const longDescriptionHtml = desc.longDescription ? renderMarkdown(desc.longDescription) : null;
const screenshots = resolveScreenshotAssets(pc, desc);
const release = formatDate(pc.releaseDate, locale);
const license = await resolveLicense(pc.legal?.license);
const features = desc.features ?? [];
const langNames = new Intl.DisplayNames([locale], { type: 'language' });
const languages = Object.keys(pc.description ?? {}).map(k => langNames.of(k) ?? k);
const platforms = pc.platforms ?? [];

const medalEmoji = { gold: '\u{1F947}', silver: '\u{1F948}', bronze: '\u{1F949}' };
const levels = ['gold', 'silver', 'bronze'];
const badgeUrls = {
  'open-source': 'https://badges.opencode.de/explanation/official-badges/open-source-badge',
  maintained: 'https://badges.opencode.de/explanation/official-badges/active-maintained-badge',
  reused: 'https://badges.opencode.de/explanation/official-badges/reuse-badge',
  security: 'https://badges.opencode.de/explanation/official-badges/security-badge',
  'supply-chain': 'https://badges.opencode.de/explanation/official-badges/supply-chain-badge',
};
const badgeDefs = [
  { key: 'open-source', icon: 'scale-balanced' },
  { key: 'maintained', icon: 'heart-pulse' },
  { key: 'reused', icon: 'arrows-rotate' },
  { key: 'security', icon: 'shield-halved' },
  { key: 'supply-chain', icon: 'link' },
].map((badge) => ({
  ...badge,
  url: badgeUrls[badge.key],
  label: t(locale, `badge_${badge.key.replace('-', '_')}`),
  description: t(locale, `badge_${badge.key.replace('-', '_')}_desc`),
  levels: levels
    .filter((level) => t(locale, `badge_${badge.key.replace('-', '_')}_${level}`) !== `badge_${badge.key.replace('-', '_')}_${level}`)
    .map((level) => ({ level, medal: medalEmoji[level], criteria: t(locale, `badge_${badge.key.replace('-', '_')}_${level}`) })),
}));
const allBadges = badges
  ? badgeDefs.map((badge) => {
      const level = badges[badge.key];
      const earned = level && level !== 'no';
      return { ...badge, earned: earned ? level : null, medal: earned ? medalEmoji[level] : null };
    })
  : [];

const levelValue = { no: 0, bronze: 1, silver: 2, gold: 3 };
const radarSize = 300;
const radarCenter = radarSize / 2;
const radarRadius = 90;
const radarPoint = (angle: number, radius: number) =>
  `${radarCenter + radius * Math.cos(angle)},${radarCenter + radius * Math.sin(angle)}`;
const radarXY = (angle: number, radius: number) => ({
  x: radarCenter + radius * Math.cos(angle),
  y: radarCenter + radius * Math.sin(angle),
});
const makeRadar = (items: { label: string; value: number }[], maxValue: number) => {
  const axes = items.map((item, index) => ({
    ...item,
    angle: (Math.PI * 2 * index) / items.length - Math.PI / 2,
  }));
  return {
    axes,
    grid: [1, 2, 3, 4, 5].map((level) =>
      axes.map((axis) => radarPoint(axis.angle, (radarRadius * level) / 5)).join(' ')
    ),
    data: axes.map((axis) => radarPoint(axis.angle, radarRadius * Math.min(axis.value / maxValue, 1))).join(' '),
  };
};
const badgeRadar = makeRadar(
  badgeDefs.map((badge) => ({
    label: badge.label,
    value: badges ? (levelValue[badges[badge.key]] ?? 0) + 1 : 1,
  })),
  5,
);
---

<Layout title={pc.name} description={desc.shortDescription} breadcrumbs={[{ label: t(locale, 'home'), href: base + "/" }, { label: t(locale, 'software'), href: base + "/software" }, { label: pc.name }]}>
  <article class="software-detail">
    <header>
      <figure class={`software-logo image-shell ${logo ? 'image-loading' : ''}`}>
        <span class="logo-placeholder" aria-hidden="true">{pc.name.charAt(0).toUpperCase()}</span>
        {logo && (
          <img src={logo.src} data-fallback={logo.fallback} class="image-fallback" alt="" fetchpriority="high" />
        )}
      </figure>
      <div>
        <h1>{pc.name} {pc.softwareVersion && <small>{pc.softwareVersion}</small>}</h1>
        <p class="short-description">{desc.shortDescription}</p>
        {pc.categories?.length > 0 && (
          <ul class="categories" aria-label="Categories">
            {pc.categories.map((c) => <li><a href={`${base}/software?category=${c}`}>{c}</a></li>)}
          </ul>
        )}
        <nav class="software-links" aria-label="Software links">
          {safeUrl(pc.url) && <a href={safeUrl(pc.url)} rel="noopener"><Fragment set:html={faIcon('code-branch')} /> {t(locale, 'source_code')}</a>}
          {safeUrl(pc.landingURL) && <a href={safeUrl(pc.landingURL)} rel="noopener"><Fragment set:html={faIcon('globe')} /> {t(locale, 'website')}</a>}
          {safeUrl(pc.documentation) && <a href={safeUrl(pc.documentation)} rel="noopener"><Fragment set:html={faIcon('book')} /> {t(locale, 'documentation')}</a>}
          {safeUrl(pc.apiDocumentation) && <a href={safeUrl(pc.apiDocumentation)} rel="noopener"><Fragment set:html={faIcon('file-code')} /> {t(locale, 'api_documentation')}</a>}
        </nav>
      </div>
    </header>

    <dl class="software-meta">
      {multiCatalog && catalogName && <><dt><Fragment set:html={faIcon('layer-group')} /> {t(locale, 'catalog_label')}</dt><dd>{catalogName}</dd></>}
      {license && <><dt><Fragment set:html={faIcon('gavel')} /> {t(locale, 'license')}</dt><dd>{license.url ? <a href={license.url}>{license.name}</a> : license.name}</dd></>}
      {release && <><dt><Fragment set:html={faIcon('calendar', 'far')} /> {t(locale, 'release_date')}</dt><dd><time datetime={release.datetime} title={release.formatted}>{release.relative}</time></dd></>}
      {pc.developmentStatus && <><dt><Fragment set:html={faIcon('circle-info')} /> {t(locale, 'status')}</dt><dd>{t(locale, 'status_' + pc.developmentStatus)}</dd></>}
      {pc.softwareType && <><dt><Fragment set:html={faIcon('cube')} /> {t(locale, 'software_type')}</dt><dd>{t(locale, 'type_' + pc.softwareType)}</dd></>}
      {pc.maintenance?.type && <><dt><Fragment set:html={faIcon('wrench')} /> {t(locale, 'maintenance_type')}</dt><dd>{t(locale, 'maintenance_' + pc.maintenance.type)}</dd></>}
      {platforms.length > 0 && <><dt><Fragment set:html={faIcon('desktop')} /> {t(locale, 'platforms')}</dt><dd>{platforms.join(', ')}</dd></>}
      {languages.length > 0 && <><dt><Fragment set:html={faIcon('language')} /> {t(locale, 'languages')}</dt><dd>{languages.join(', ')}</dd></>}
    </dl>

    {allBadges.length > 0 && (
      <section class="software-badges opencode-badges" aria-label={t(locale, 'badges')}>
        <div class="opencode-badge-list">
          {allBadges.map((badge) => (
            <Fragment>
              <button class={`badge ${badge.earned ? '' : 'badge-unearned'}`} type="button" popovertarget={`badge-${badge.key}`} style={`anchor-name: --badge-${badge.key}`}>
                <span class={`badge-medal ${badge.medal ? '' : 'badge-medal-locked'}`}>{badge.medal ?? '\u{1F3C5}'}</span>
                {badge.label}
              </button>
              <div id={`badge-${badge.key}`} popover style={`position-anchor: --badge-${badge.key}`}>
                <h3>{badge.label} {t(locale, 'badge_label')}</h3>
                <p>{badge.description}</p>
                <dl class="badge-levels">
                  {badge.levels.map((level) => (
                    <Fragment>
                      <dt class={level.level === badge.earned ? 'current' : ''}>{level.medal} {t(locale, `badge_${level.level}`)}</dt>
                      <dd class={level.level === badge.earned ? 'current' : ''}>{level.criteria}</dd>
                    </Fragment>
                  ))}
                </dl>
                <a class="badge-link" href={badge.url} target="_blank" rel="noopener">{t(locale, 'badge_learn_more')} <Fragment set:html={faIcon('arrow-up-right-from-square')} /></a>
              </div>
            </Fragment>
          ))}
        </div>
        <button class="badge badge-chart" type="button" popovertarget="radar-popover" style="anchor-name: --radar-button" aria-label={t(locale, 'badges')}>
          <Fragment set:html={faIcon('chart-pie')} />
        </button>
        <div id="radar-popover" popover style="position-anchor: --radar-button" data-radar-tabs>
          <div class="radar-tabs" role="tablist" aria-label={t(locale, 'badges')}>
            <button id="radar-tab-badges" class="radar-tab" type="button" role="tab" aria-selected="true" aria-controls="radar-panel-badges" data-radar-tab="badges">{t(locale, 'badges')}</button>
            <button id="radar-tab-activity" class="radar-tab" type="button" role="tab" aria-selected="false" aria-controls="radar-panel-activity" data-radar-tab="activity">{t(locale, 'activity_score')}</button>
          </div>
          <div id="radar-panel-badges" class="radar-tabpanel" role="tabpanel" aria-labelledby="radar-tab-badges" data-radar-panel="badges">
            <svg class="radar-chart" viewBox={`0 0 ${radarSize} ${radarSize}`} role="img" aria-label={t(locale, 'badges')}>
              {badgeRadar.grid.map((points) => <polygon points={points} class="radar-ring" />)}
              {badgeRadar.axes.map((axis) => {
                const to = radarXY(axis.angle, radarRadius);
                return <line x1={radarCenter} y1={radarCenter} x2={to.x} y2={to.y} class="radar-axis" />;
              })}
              <polygon points={badgeRadar.data} class="radar-fill" />
              {badgeRadar.axes.map((axis) => {
                const position = radarXY(axis.angle, radarRadius + 24);
                return <text x={position.x} y={position.y} class="radar-label" text-anchor="middle" dominant-baseline="central">{axis.label}</text>;
              })}
            </svg>
          </div>
          <div id="radar-panel-activity" class="radar-tabpanel" role="tabpanel" aria-labelledby="radar-tab-activity" data-radar-panel="activity" hidden>
            {activity
              ? <ActivityRadar client:load softwareId={software.id} activity={activity} stats={stats} locale={locale} />
              : <p class="radar-empty">{t(locale, 'no_activity_data')}</p>}
          </div>
        </div>
      </section>
    )}

    {activity && <SoftwareMetrics client:visible softwareId={software.id} activity={activity} stats={stats} locale={locale} />}

    {features.length > 0 && (
      <section class="software-features">
        <h2><Fragment set:html={faIcon('list-check')} /> {t(locale, 'features')}</h2>
        <ul>
          {features.map((f) => <li>{f}</li>)}
        </ul>
      </section>
    )}

    {screenshots.length > 0 && (
      <section class="software-screenshots">
        <h2><Fragment set:html={faIcon('images')} /> {t(locale, 'screenshots')}</h2>
        <div class="screenshot-grid">
          {screenshots.map((asset, i) => (
            <button type="button" data-index={i} class="screenshot-thumb">
              <span class="image-skeleton" aria-hidden="true"></span>
              <img src={asset.src} data-fallback={asset.fallback} class="image-fallback" alt="" loading="lazy" />
            </button>
          ))}
        </div>
        <dialog id="lightbox">
          <img id="lightbox-img" src="" alt="" />
          <nav>
            <button type="button" id="lightbox-prev" aria-label="Previous">&larr;</button>
            <button type="button" id="lightbox-next" aria-label="Next">&rarr;</button>
          </nav>
          <button type="button" id="lightbox-close" aria-label="Close">&times;</button>
        </dialog>
      </section>
    )}

    {longDescriptionHtml && (
      <section class="software-description">
        <h2><Fragment set:html={faIcon('align-left')} /> {t(locale, 'description')}</h2>
        <div set:html={longDescriptionHtml} />
      </section>
    )}

    {pc.maintenance?.contacts?.length > 0 && (
      <section class="software-contacts">
        <h2><Fragment set:html={faIcon('address-book')} /> {t(locale, 'contacts')}</h2>
        <ul>
          {pc.maintenance.contacts.map((c) => (
            <li>
              {safeUrl(`mailto:${c.email}`) ? <a href={`mailto:${c.email}`}>{c.name}</a> : c.name}
              {c.phone && <> {c.phone}</>}
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</Layout>

<script>
  document.querySelectorAll<HTMLElement>('[data-radar-tabs]').forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-radar-tab]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-radar-panel]'));
    for (const tab of tabs) {
      tab.addEventListener('click', () => {
        const active = tab.dataset.radarTab;
        for (const candidate of tabs) {
          candidate.setAttribute('aria-selected', String(candidate === tab));
        }
        for (const panel of panels) {
          panel.hidden = panel.dataset.radarPanel !== active;
        }
      });
    }
  });
</script>

<script>
  const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
  const img = document.getElementById('lightbox-img') as HTMLImageElement | null;
  if (dialog && img) {
    const thumbs = document.querySelectorAll<HTMLButtonElement>('.screenshot-thumb');
    let current = 0;

    const src = (i: number) => thumbs[i]?.querySelector('img')?.src ?? '';

    const show = (i: number) => {
      current = (i + thumbs.length) % thumbs.length;
      img.src = src(current);
    };

    thumbs.forEach(t => t.addEventListener('click', () => {
      show(Number(t.dataset.index));
      dialog.showModal();
    }));

    document.getElementById('lightbox-prev')?.addEventListener('click', () => show(current - 1));
    document.getElementById('lightbox-next')?.addEventListener('click', () => show(current + 1));
    document.getElementById('lightbox-close')?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => { if (e.target === dialog) dialog.close(); });

    document.addEventListener('keydown', (e) => {
      if (!dialog.open) return;
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });
  }
</script>
