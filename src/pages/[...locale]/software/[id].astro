---
import Layout from '../../../layouts/Layout.astro';
import { faIcon } from '../../../lib/icons.js';
import { fetchAllSoftware, fetchCatalogs } from '../../../lib/api.js';
import { resolveLogo, absoluteUrl } from '../../../lib/absoluteUrl.js';
import { base } from '../../../lib/url.js';
import { renderMarkdown } from '../../../lib/markdown.ts';
import { t, localizeDescription } from '../../../lib/i18n.js';
import { formatDate } from '../../../lib/date.js';
import { resolveLicense } from '../../../lib/license.js';
import { safeUrl } from '../../../lib/sanitize.js';

export async function getStaticPaths() {
  const software = await fetchAllSoftware();
  const catalogs = await fetchCatalogs();
  const catalogMap = Object.fromEntries(catalogs.map((c) => [c.id, c]));
  const multiCatalog = catalogs.length > 1;
  const locales = [undefined, 'it'];
  return locales.flatMap((locale) =>
    software.map((s) => ({
      params: { locale, id: s.id },
      props: {
        software: s,
        catalogName: catalogMap[s.catalogId]?.name ?? null,
        multiCatalog,
      },
    }))
  );
}

const locale = Astro.currentLocale ?? 'en';
const { software, catalogName, multiCatalog } = Astro.props;
const pc = software.publiccode;

const desc = localizeDescription(pc.description, locale);
const logo = resolveLogo(pc);
const longDescriptionHtml = desc.longDescription ? renderMarkdown(desc.longDescription) : null;
const screenshots = (desc.screenshots ?? [])
  .map((s) => absoluteUrl(s, pc.url))
  .filter(Boolean);
const release = formatDate(pc.releaseDate, locale);
const license = await resolveLicense(pc.legal?.license);
const features = desc.features ?? [];
const languages = Object.keys(pc.description ?? {}).map(k => k.replace(/-.*/, ''));
const platforms = pc.platforms ?? [];
---

<Layout title={pc.name} description={desc.shortDescription} breadcrumbs={[{ label: t(locale, 'home'), href: base + "/" }, { label: t(locale, 'software'), href: base + "/software" }, { label: pc.name }]}>
  <article class="software-detail">
    <header>
      <figure class="software-logo">
        <span class="logo-placeholder" aria-hidden="true">{pc.name.charAt(0).toUpperCase()}</span>
        {logo && (
          <img src={logo} alt="" fetchpriority="high"
            onload="this.previousElementSibling.style.display='none'"
            onerror="this.style.display='none'" />
        )}
      </figure>
      <div>
        <h1>{pc.name} {pc.softwareVersion && <small>{pc.softwareVersion}</small>}</h1>
        <p class="short-description">{desc.shortDescription}</p>
        {pc.categories?.length > 0 && (
          <ul class="categories" aria-label="Categories">
            {pc.categories.map((c) => <li><a href={`${base}/software?category=${c}`}>{c}</a></li>)}
          </ul>
        )}
        <nav class="software-links" aria-label="Software links">
          {safeUrl(pc.url) && <a href={safeUrl(pc.url)} rel="noopener"><Fragment set:html={faIcon('code-branch')} /> {t(locale, 'source_code')}</a>}
          {safeUrl(pc.landingURL) && <a href={safeUrl(pc.landingURL)} rel="noopener"><Fragment set:html={faIcon('globe')} /> {t(locale, 'website')}</a>}
          {safeUrl(pc.documentation) && <a href={safeUrl(pc.documentation)} rel="noopener"><Fragment set:html={faIcon('book')} /> {t(locale, 'documentation')}</a>}
          {safeUrl(pc.apiDocumentation) && <a href={safeUrl(pc.apiDocumentation)} rel="noopener"><Fragment set:html={faIcon('file-code')} /> {t(locale, 'api_documentation')}</a>}
        </nav>
      </div>
    </header>

    <dl class="software-meta">
      {multiCatalog && catalogName && <><dt><Fragment set:html={faIcon('layer-group')} /> {t(locale, 'catalog_label')}</dt><dd>{catalogName}</dd></>}
      {license && <><dt><Fragment set:html={faIcon('gavel')} /> {t(locale, 'license')}</dt><dd>{license.url ? <a href={license.url}>{license.name}</a> : license.name}</dd></>}
      {release && <><dt><Fragment set:html={faIcon('calendar', 'far')} /> {t(locale, 'release_date')}</dt><dd><time datetime={release.datetime} title={release.formatted}>{release.relative}</time></dd></>}
      {pc.developmentStatus && <><dt><Fragment set:html={faIcon('circle-info')} /> {t(locale, 'status')}</dt><dd>{pc.developmentStatus}</dd></>}
      {pc.softwareType && <><dt><Fragment set:html={faIcon('cube')} /> {t(locale, 'software_type')}</dt><dd>{pc.softwareType}</dd></>}
      {pc.maintenance?.type && <><dt><Fragment set:html={faIcon('wrench')} /> {t(locale, 'maintenance_type')}</dt><dd>{pc.maintenance.type}</dd></>}
      {platforms.length > 0 && <><dt><Fragment set:html={faIcon('desktop')} /> {t(locale, 'platforms')}</dt><dd>{platforms.join(', ')}</dd></>}
      {languages.length > 0 && <><dt><Fragment set:html={faIcon('language')} /> {t(locale, 'languages')}</dt><dd>{languages.join(', ')}</dd></>}
    </dl>

    {features.length > 0 && (
      <section class="software-features">
        <h2><Fragment set:html={faIcon('list-check')} /> {t(locale, 'features')}</h2>
        <ul>
          {features.map((f) => <li>{f}</li>)}
        </ul>
      </section>
    )}

    {screenshots.length > 0 && (
      <section class="software-screenshots">
        <h2><Fragment set:html={faIcon('images')} /> {t(locale, 'screenshots')}</h2>
        <div class="screenshot-grid">
          {screenshots.map((src, i) => (
            <button type="button" data-index={i} class="screenshot-thumb">
              <img src={src} alt="" loading="lazy" />
            </button>
          ))}
        </div>
        <dialog id="lightbox">
          <img id="lightbox-img" src="" alt="" />
          <nav>
            <button type="button" id="lightbox-prev" aria-label="Previous">&larr;</button>
            <button type="button" id="lightbox-next" aria-label="Next">&rarr;</button>
          </nav>
          <button type="button" id="lightbox-close" aria-label="Close">&times;</button>
        </dialog>
      </section>
    )}

    {longDescriptionHtml && (
      <section class="software-description">
        <h2><Fragment set:html={faIcon('align-left')} /> {t(locale, 'description')}</h2>
        <div set:html={longDescriptionHtml} />
      </section>
    )}

    {pc.maintenance?.contacts?.length > 0 && (
      <section class="software-contacts">
        <h2><Fragment set:html={faIcon('address-book')} /> {t(locale, 'contacts')}</h2>
        <ul>
          {pc.maintenance.contacts.map((c) => (
            <li>
              {safeUrl(`mailto:${c.email}`) ? <a href={`mailto:${c.email}`}>{c.name}</a> : c.name}
              {c.phone && <> {c.phone}</>}
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</Layout>

<script>
  const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
  const img = document.getElementById('lightbox-img') as HTMLImageElement | null;
  if (dialog && img) {
    const thumbs = document.querySelectorAll<HTMLButtonElement>('.screenshot-thumb');
    const srcs = Array.from(thumbs).map(t => t.querySelector('img')!.src);
    let current = 0;

    const show = (i: number) => {
      current = (i + srcs.length) % srcs.length;
      img.src = srcs[current];
    };

    thumbs.forEach(t => t.addEventListener('click', () => {
      show(Number(t.dataset.index));
      dialog.showModal();
    }));

    document.getElementById('lightbox-prev')?.addEventListener('click', () => show(current - 1));
    document.getElementById('lightbox-next')?.addEventListener('click', () => show(current + 1));
    document.getElementById('lightbox-close')?.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => { if (e.target === dialog) dialog.close(); });

    document.addEventListener('keydown', (e) => {
      if (!dialog.open) return;
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });
  }
</script>
