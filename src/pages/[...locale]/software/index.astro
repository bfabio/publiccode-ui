---
import Layout from '../../../layouts/Layout.astro';
import { fetchAllSoftware } from '../../../lib/api.js';
import { resolveLogo } from '../../../lib/absoluteUrl.js';
import { base } from '../../../lib/url.js';
import { t, localizeDescription } from '../../../lib/i18n.js';
import { SoftwareList } from '../../../components/SoftwareList';
import { resolveLicense } from '../../../lib/license.js';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    { params: { locale: 'it' } },
  ];
}

const locale = Astro.currentLocale ?? 'en';
const allSoftware = await fetchAllSoftware();

const items = await Promise.all(allSoftware.map(async (s) => {
  const pc = s.publiccode;
  const desc = localizeDescription(pc.description, locale);
  const license = await resolveLicense(pc.legal?.license);
  return {
    id: s.id,
    name: pc.name,
    shortDescription: desc.shortDescription ?? '',
    categories: pc.categories ?? [],
    releaseDate: pc.releaseDate ?? '',
    license: license ? { id: license.id, name: license.name, url: license.url } : null,
    logo: resolveLogo(pc),
    developmentStatus: pc.developmentStatus ?? '',
    softwareType: pc.softwareType ?? '',
    intendedAudience: pc.intendedAudience?.scope ?? [],
  };
}));
---

<Layout title={t(locale, 'catalog')} breadcrumbs={[{ label: t(locale, 'home'), href: base + "/" }, { label: t(locale, 'software') }]}>
  <h1>{t(locale, 'catalog')}</h1>
  <p>{items.length} {t(locale, 'software_count')}</p>
  <SoftwareList client:visible items={items} base={base} locale={locale} labels={{
    allCategories: t(locale, 'all_categories'),
    allStatuses: t(locale, 'all_statuses'),
    allAudiences: t(locale, 'all_audiences'),
    sortNameAsc: t(locale, 'sort_name_asc'),
    sortNameDesc: t(locale, 'sort_name_desc'),
    sortReleaseDesc: t(locale, 'sort_release_desc'),
    sortReleaseAsc: t(locale, 'sort_release_asc'),
    results: t(locale, 'results'),
    noResults: t(locale, 'no_results'),
    clearFilters: t(locale, 'clear_filters'),
    allTypes: t(locale, 'all_types'),
    searchPlaceholder: t(locale, 'search_placeholder'),
    filters: t(locale, 'filters'),
    sortBy: t(locale, 'sort_by'),
  }} />
</Layout>
