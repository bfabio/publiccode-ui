---
import { getAbsoluteLocaleUrl } from 'astro:i18n';

interface Props {
  title: string;
  breadcrumbs?: { label: string; href?: string }[];
}

const { title, breadcrumbs = [] } = Astro.props;
const locale = Astro.currentLocale ?? 'en';
const routePath = Astro.url.pathname.replace(/^\/it/, '') || '/';
const enUrl = getAbsoluteLocaleUrl('en', routePath);
const itUrl = getAbsoluteLocaleUrl('it', routePath);
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="it" href={itUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    <style is:global>
      body { font-family: sans-serif; margin: 0; color: #333; }
      .breadcrumb { font-size: 0.85rem; color: #666; margin: 1rem 0; }
      .breadcrumb a { color: #0066cc; text-decoration: none; }
      .breadcrumb a:hover { text-decoration: underline; }
      main { max-width: 900px; margin: 0 auto; padding: 1rem 2rem 2rem; }
    </style>
  </head>
  <body>
    <main>
      {breadcrumbs.length > 0 && (
        <div class="breadcrumb">
          {breadcrumbs.map((b, i) => (
            <>
              {i > 0 && " / "}
              {b.href ? <a href={b.href}>{b.label}</a> : <span>{b.label}</span>}
            </>
          ))}
        </div>
      )}
      <slot />
    </main>
  </body>
</html>
