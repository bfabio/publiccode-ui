---
import { fetchAllSoftware } from '../../lib/api.js';
import { resolveLogo, absoluteUrl } from '../../lib/absoluteUrl.js';
import { base } from '../../lib/url.js';
import { marked } from 'marked';

export async function getStaticPaths() {
  const software = await fetchAllSoftware();
  return software.map((s) => ({
    params: { id: s.id },
    props: { software: s },
  }));
}

const { software } = Astro.props;
const pc = software.publiccode;

const desc = pc.description?.en ?? pc.description?.[Object.keys(pc.description ?? {})[0]] ?? {};
const logo = resolveLogo(pc);
const longDescriptionHtml = desc.longDescription ? marked.parse(desc.longDescription) : null;
const screenshots = (desc.screenshots ?? [])
  .map((s) => absoluteUrl(s, pc.url))
  .filter(Boolean);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{pc.name}</title>
  </head>
  <body>
    <nav>
      <a href={base + "/"}>Home</a> /
      <a href={base + "/software"}>Software</a> /
      {pc.name}
    </nav>

    <h1>{pc.name}</h1>

    {logo && <img src={logo} alt="" width="100" />}

    <p>{desc.shortDescription}</p>

    <dl>
      {pc.legal?.license && <><dt>License</dt><dd>{pc.legal.license}</dd></>}
      {pc.releaseDate && <><dt>Release date</dt><dd>{pc.releaseDate}</dd></>}
      {pc.softwareVersion && <><dt>Version</dt><dd>{pc.softwareVersion}</dd></>}
      {pc.developmentStatus && <><dt>Status</dt><dd>{pc.developmentStatus}</dd></>}
      {pc.url && <><dt>Repository</dt><dd><a href={pc.url}>{pc.url}</a></dd></>}
      {pc.landingURL && <><dt>Website</dt><dd><a href={pc.landingURL}>{pc.landingURL}</a></dd></>}
    </dl>

    {pc.categories?.length > 0 && (
      <div>
        <strong>Categories:</strong> {pc.categories.join(', ')}
      </div>
    )}

    {screenshots.length > 0 && (
      <div>
        <h2>Screenshots</h2>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;">
          {screenshots.map((src) => (
            <a href={src} target="_blank" rel="noopener">
              <img src={src} alt="" loading="lazy" style="max-height:200px;max-width:300px;object-fit:contain;border:1px solid #e0e0e0;" />
            </a>
          ))}
        </div>
      </div>
    )}

    {longDescriptionHtml && (
      <div>
        <h2>Description</h2>
        <div set:html={longDescriptionHtml} />
      </div>
    )}

    {pc.maintenance?.contacts?.length > 0 && (
      <div>
        <h2>Contacts</h2>
        <ul>
          {pc.maintenance.contacts.map((c) => (
            <li>
              {c.email ? <a href={`mailto:${c.email}`}>{c.name}</a> : c.name}
              {c.phone && <> — {c.phone}</>}
            </li>
          ))}
        </ul>
      </div>
    )}
  </body>
</html>
