---
import { fetchAllSoftware } from '../../lib/api.js';
import { resolveLogo } from '../../lib/absoluteUrl.js';
import { base } from '../../lib/url.js';
import { SoftwareList } from '../../components/SoftwareList';

const allSoftware = await fetchAllSoftware();

const localize = (description) => {
  if (!description) return {};
  return description.en ?? description[Object.keys(description)[0]] ?? {};
};

const items = allSoftware.map((s) => {
  const pc = s.publiccode;
  const desc = localize(pc.description);
  return {
    id: s.id,
    name: pc.name,
    shortDescription: desc.shortDescription ?? '',
    categories: pc.categories ?? [],
    releaseDate: pc.releaseDate ?? '',
    license: pc.legal?.license ?? '',
    logo: resolveLogo(pc),
  };
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Software catalog</title>
    <style>
      body { font-family: sans-serif; max-width: 900px; margin: 0 auto; padding: 1rem 2rem; }
      nav { margin-bottom: 2rem; }
      .count { color: #666; font-size: 0.9rem; }
      .item { display: grid; grid-template-columns: 64px 1fr auto; gap: 1rem; align-items: start; padding: 1rem 0; border-top: 1px solid #e0e0e0; }
      .logo { width: 64px; height: 64px; object-fit: contain; }
      .logo-box { width: 64px; height: 64px; background: #f0f0f0; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #bbb; font-size: 1.5rem; }
      .name { font-size: 1.1rem; font-weight: 600; text-decoration: none; color: inherit; }
      .name:hover { text-decoration: underline; }
      .desc { margin: 0.25rem 0 0.5rem; color: #444; font-size: 0.9rem; }
      .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
      .tag { font-size: 0.75rem; background: #f0f0f0; border-radius: 4px; padding: 2px 8px; text-transform: uppercase; }
      .meta { font-size: 0.8rem; color: #666; white-space: nowrap; text-align: right; }
      .meta div { margin-bottom: 0.25rem; }
    </style>
  </head>
  <body>
    <nav><a href={base + "/"}>Home</a></nav>
    <h1>Software <span class="count">({items.length})</span></h1>

    <SoftwareList client:load items={items} base={base} />
  </body>
</html>
