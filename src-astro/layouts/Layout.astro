---
import { base } from '../lib/url.js';

interface Props {
  title: string;
  breadcrumbs?: { label: string; href?: string }[];
}

const { title, breadcrumbs = [] } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style is:global>
      body { font-family: sans-serif; margin: 0; color: #333; }
      header { background: #004080; color: #fff; padding: 0.75rem 0; }
      header .container { max-width: 900px; margin: 0 auto; padding: 0 2rem; display: flex; align-items: center; gap: 2rem; }
      header a { color: #fff; text-decoration: none; font-weight: 600; }
      header nav a { font-weight: 400; font-size: 0.9rem; }
      header nav a:hover { text-decoration: underline; }
      .breadcrumb { font-size: 0.85rem; color: #666; margin: 1rem 0; }
      .breadcrumb a { color: #0066cc; text-decoration: none; }
      .breadcrumb a:hover { text-decoration: underline; }
      main { max-width: 900px; margin: 0 auto; padding: 0 2rem 2rem; }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <a href={base + "/"}>EU Public Code</a>
        <nav>
          <a href={base + "/software"}>Software</a>
        </nav>
      </div>
    </header>
    <main>
      {breadcrumbs.length > 0 && (
        <div class="breadcrumb">
          {breadcrumbs.map((b, i) => (
            <>
              {i > 0 && " / "}
              {b.href ? <a href={b.href}>{b.label}</a> : <span>{b.label}</span>}
            </>
          ))}
        </div>
      )}
      <slot />
    </main>
  </body>
</html>
